generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== ENUMS ==========

enum TableStatus {
  EMPTY
  SEATED
  ORDERING
  SERVING
  NEED_PAYMENT
  NEED_CLEAN
}

enum TableSessionStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum ItemStatus {
  NEW
  COOKING
  READY
  SERVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ShiftExpenseType {
  REFUND
  INTERNAL_SPEND
  PURCHASE
  OTHER
}

// ========== MODELS ==========

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Override permissions for specific users
  userPermissions UserPermission[]

  // Relations
  orders        Order[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  shiftsOpened   Shift[]        @relation("ShiftOpenedBy")
  shiftsClosed   Shift[]        @relation("ShiftClosedBy")
  shiftExpensesCreated ShiftExpense[]
  shiftApprovals Shift[]        @relation("ShiftApprovedBy")

  @@index([email])
  @@index([roleId])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@index([name])
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., USER_READ, MENU_CREATE
  name        String
  description String?
  category    String? // Group permissions: USER, MENU, ORDER, KITCHEN, etc.
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([code])
  @@index([category])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems MenuItem[]

  @@index([isActive])
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  /// Manager-selected labels: BEST_SELLER, RECOMMENDED, CHEFS_PICK, NEW
  tags        String[] @default([])
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]

  @@index([categoryId])
  @@index([isAvailable])
}

model Table {
  id         String      @id @default(uuid())
  tableCode  String      @unique // e.g., T01, T02
  tableName  String // e.g., "Table 1", "VIP Table"
  capacity   Int
  qrCode     String?     @unique
  status     TableStatus @default(EMPTY)
  floor      String? // Optional: ground, first, etc.
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  sessions     TableSession[]
  reservations Reservation[]

  @@index([tableCode])
  @@index([status])
}

model TableSession {
  id         String             @id @default(uuid())
  startTime  DateTime           @default(now())
  endTime    DateTime?
  status     TableSessionStatus @default(OPEN)
  guestCount Int?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tableId String
  table   Table  @relation(fields: [tableId], references: [id])

  orders Order[]

  @@index([tableId])
  @@index([status])
}

model Order {
  id         String      @id @default(uuid())
  orderNumber String     @unique // Auto-generated: ORD-20231201-001
  type       OrderType   @default(DINE_IN)
  status     OrderStatus @default(NEW)
  subtotal   Decimal     @db.Decimal(10, 2)
  tax        Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @db.Decimal(10, 2)
  notes      String? // Customer notes
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  /// POS: gán khi tạo đơn (ca đang OPEN). Đơn cũ có thể null.
  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  // For DINE_IN orders
  sessionId String?
  session   TableSession? @relation(fields: [sessionId], references: [id])

  // Staff who confirmed the order
  confirmedById String?
  confirmedBy   User?   @relation(fields: [confirmedById], references: [id])

  orderItems  OrderItem[]
  payment     Payment?
  invoice     Invoice?
  staffCalls  StaffCall[]

  @@index([orderNumber])
  @@index([status])
  @@index([type])
  @@index([sessionId])
  @@index([shiftId])
}

model Shift {
  id           String      @id @default(uuid())
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  /// Ngày làm việc (VN) để báo cáo — gốc theo openedAt
  shiftDateYmd String

  openedById String
  openedBy   User   @relation("ShiftOpenedBy", fields: [openedById], references: [id])

  closedById String?
  closedBy   User?  @relation("ShiftClosedBy", fields: [closedById], references: [id])

  openingCash Decimal @db.Decimal(12, 2)

  /// Snapshot lúc kết ca (đồng bộ kiểm kê)
  expectedCash     Decimal? @db.Decimal(12, 2)
  actualCash         Decimal? @db.Decimal(12, 2)
  cashSalesAtClose   Decimal? @db.Decimal(12, 2)
  expensesAtClose    Decimal? @db.Decimal(12, 2)
  difference         Decimal? @db.Decimal(12, 2)
  differenceReason   String?
  /// Duyệt chênh lệch (khi có quyền SHIFT_APPROVE_DIFF)
  approvedByManagerId String?
  approvedByManager    User?   @relation("ShiftApprovedBy", fields: [approvedByManagerId], references: [id])

  orders   Order[]
  expenses ShiftExpense[]

  @@index([status])
  @@index([shiftDateYmd])
  @@index([openedAt])
}

model ShiftExpense {
  id        String           @id @default(uuid())
  shiftId   String
  shift     Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(12, 2)
  type      ShiftExpenseType
  note      String?
  createdAt DateTime         @default(now())
  createdById String?
  createdBy   User?          @relation(fields: [createdById], references: [id])

  @@index([shiftId])
  @@index([createdAt])
}

model OrderItem {
  id       String     @id @default(uuid())
  quantity Int
  price    Decimal    @db.Decimal(10, 2) // Price at time of order
  subtotal Decimal    @db.Decimal(10, 2)
  status   ItemStatus @default(NEW)
  notes    String? // Special requests
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([menuItemId])
}

model Payment {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod String? // cash, card, transfer
  status        PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([status])
}

model Invoice {
  id           String   @id @default(uuid())
  invoiceNumber String  @unique
  issuedAt     DateTime @default(now())
  sentToEmail  String?
  emailSentAt  DateTime?
  createdAt    DateTime @default(now())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([invoiceNumber])
}

model StaffCall {
  id         String   @id @default(uuid())
  reason     String? // "Need help", "Request bill", etc.
  isResolved Boolean  @default(false)
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([isResolved])
}

model Reservation {
  id            String            @id @default(uuid())
  customerName  String
  customerPhone String
  customerEmail String?
  guestCount    Int
  reservationTime DateTime
  status        ReservationStatus @default(PENDING)
  notes         String?
  confirmationCode String         @unique
  checkedInAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  @@index([status])
  @@index([reservationTime])
  @@index([tableId])
}

/// Cấu hình singleton — thông tin nhà hàng & template email hóa đơn
model RestaurantSettings {
  id String @id @default("default")

  restaurantName String @default("Nhà hàng")
  hotline        String @default("")
  address        String @default("")
  website        String @default("")
  /// From SMTP / gửi mail
  emailFrom      String?

  /// Handlebars: email chi tiết (không đính PDF)
  emailTemplatePlain String @db.Text
  /// Handlebars: email ngắn khi đính kèm PDF
  emailTemplatePdf   String @db.Text

  /// Giờ mở/đóng cửa (HH:mm, Asia/Ho_Chi_Minh) — dùng để tự mở ca khi chưa có ca thủ công
  operationsOpenTime  String @default("10:00")
  operationsCloseTime String @default("23:00")

  updatedAt DateTime @updatedAt
}

model StaffNotification {
  id        String   @id @default(uuid())
  type      String
  title     String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType String // User, Order, MenuItem, etc.
  entityId   String?
  metadata   Json? // Additional context
  ipAddress  String?
  createdAt  DateTime @default(now())

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType])
  @@index([createdAt])
}
