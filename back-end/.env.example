# Database - Neon PostgreSQL Online (lấy connection string từ Team Lead)
# Format: postgresql://USER:PASS@HOST/neondb?sslmode=require
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV="development"

# Frontend URL (CORS + Socket.io). Nhiều URL cách nhau bởi dấu phẩy.
# Local: http://localhost:3001
# Test điện thoại cùng WiFi: thay 192.168.x.x bằng IPv4 máy tính (ipconfig), ví dụ:
# FRONTEND_URL="http://localhost:3001,http://192.168.1.100:3001"
FRONTEND_URL="http://localhost:3001"

# Gmail SMTP (Mật khẩu ứng dụng — không dùng mật khẩu đăng nhập thường)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="nguyentien3001004@gmail.com"
SMTP_PASS="kxqf clms qekb ikkp "
SMTP_FROM="The Albion <nguyentien3001004@gmail.com>"

